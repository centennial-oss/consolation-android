<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Consolation" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/brand_fuchsia</item>
        <item name="colorSecondaryVariant">@color/brand_fuchsia</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorControlActivated">@color/brand_fuchsia</item>
        <item name="android:colorAccent">@color/brand_fuchsia</item>
        <item name="popupMenuStyle">@style/Widget.Consolation.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.Consolation.PopupMenu</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Widget.Consolation.PopupMenu" parent="@style/Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_menu_modern</item>
        <item name="android:itemTextAppearance">@style/TextAppearance.Consolation.PopupMenu</item>
    </style>

    <style name="ThemeOverlay.Consolation.PopupMenu" parent="@style/ThemeOverlay.AppCompat.Dark">
        <item name="android:popupBackground">@drawable/bg_popup_menu_modern</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/white</item>
        <item name="android:itemTextAppearance">@style/TextAppearance.Consolation.PopupMenu</item>
        <item name="colorControlActivated">@color/brand_fuchsia</item>
        <item name="colorAccent">@color/brand_fuchsia</item>
    </style>

    <style name="TextAppearance.Consolation.PopupMenu" parent="@style/TextAppearance.AppCompat.Widget.PopupMenu.Large">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">18sp</item>
    </style>
</resources>
